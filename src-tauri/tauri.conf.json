{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "灵机魔盒",
  "version": "1.0.0",
  "identifier": "com.lingjistudio.moonbox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "灵机魔盒",
        "width": 400,
        "height": 740,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lingjistudio/moonbox-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBOUNDQTkwRDZERUQ2MkMKUldRczF0N1drTXFjK3NxZEtIQjd0cGdtcFhDOHprTUhwckpUbGNybTJSZWU0aDZaSkNFUCt1Qi8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/frpc"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {}
    }
  }
}
